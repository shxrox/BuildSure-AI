{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": "./src",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ]
  },

  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}